{
    "name": "paymob-community/laravel-paymob",
    "description": "A Cashier-inspired Laravel package for Paymob payments, saved cards, and subscriptions.",
    "keywords": [
        "laravel",
        "paymob",
        "payments",
        "subscriptions",
        "cashier",
        "egypt",
        "ksa",
        "uae",
        "oman"
    ],
    "license": "MIT",
    "type": "library",
    "require": {
        "php": "^8.2",
        "illuminate/cache": "^11.0|^12.0|^13.0",
        "illuminate/console": "^11.0|^12.0|^13.0",
        "illuminate/contracts": "^11.0|^12.0|^13.0",
        "illuminate/database": "^11.0|^12.0|^13.0",
        "illuminate/encryption": "^11.0|^12.0|^13.0",
        "illuminate/events": "^11.0|^12.0|^13.0",
        "illuminate/http": "^11.0|^12.0|^13.0",
        "illuminate/routing": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "laravel/pint": "^1.24",
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^3.8|^4.0",
        "pestphp/pest-plugin-laravel": "^3.2|^4.0"
    },
    "autoload": {
        "psr-4": {
            "Paymob\\Laravel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Paymob\\Laravel\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Paymob\\Laravel\\PaymobServiceProvider"
            ],
            "aliases": {
                "Paymob": "Paymob\\Laravel\\Facades\\Paymob"
            }
        }
    },
    "scripts": {
        "test": "pest",
        "lint": "pint --test",
        "format": "pint"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
