{
    "name": "ahmed-abd0/laravel-paymob",
    "description": "A Cashier-inspired Laravel package for Paymob payments, saved cards, subscriptions, refunds, webhooks, transaction inquiry, and Quick Links.",
    "keywords": [
        "laravel",
        "paymob",
        "payments",
        "payment-gateway",
        "subscriptions",
        "recurring-payments",
        "cashier",
        "saved-cards",
        "webhooks",
        "refunds",
        "egypt",
        "ksa",
        "saudi-arabia",
        "uae",
        "oman"
    ],
    "homepage": "https://github.com/ahmed-abd0/laravel-paymob",
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Ahmed Abdo",
            "homepage": "https://github.com/ahmed-abd0",
            "role": "Developer"
        }
    ],
    "support": {
        "issues": "https://github.com/ahmed-abd0/laravel-paymob/issues",
        "source": "https://github.com/ahmed-abd0/laravel-paymob"
    },
    "require": {
        "php": "^8.2",
        "illuminate/cache": "^11.0|^12.0|^13.0",
        "illuminate/console": "^11.0|^12.0|^13.0",
        "illuminate/contracts": "^11.0|^12.0|^13.0",
        "illuminate/database": "^11.0|^12.0|^13.0",
        "illuminate/encryption": "^11.0|^12.0|^13.0",
        "illuminate/events": "^11.0|^12.0|^13.0",
        "illuminate/http": "^11.0|^12.0|^13.0",
        "illuminate/routing": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "laravel/pint": "^1.24",
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^3.8|^4.0",
        "pestphp/pest-plugin-laravel": "^3.2|^4.0"
    },
    "autoload": {
        "psr-4": {
            "Paymob\\Laravel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Paymob\\Laravel\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Paymob\\Laravel\\PaymobServiceProvider"
            ],
            "aliases": {
                "Paymob": "Paymob\\Laravel\\Facades\\Paymob"
            }
        }
    },
    "scripts": {
        "test": "@php vendor/bin/pest",
        "test:unit": "@php vendor/bin/pest --testsuite=Package",
        "test:coverage": "@php vendor/bin/pest --coverage",
        "lint": "@php vendor/bin/pint --test",
        "format": "@php vendor/bin/pint",
        "check": [
            "@lint",
            "@test"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}